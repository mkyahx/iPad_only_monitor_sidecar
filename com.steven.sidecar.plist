<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.steven.sidecar</string>

	<key>ProgramArguments</key>
	<array>
		<string>/bin/zsh</string>
		<string>-lc</string>
		<string>sleep 5; /usr/bin/osascript /Users/steven/tools/sidecar.applescript</string>
	</array>

	<key>RunAtLoad</key>
	<true/>

	<key>StandardOutPath</key>
	<string>/Users/steven/tools/sidecar.launchd.log</string>

	<key>StandardErrorPath</key>
	<string>/Users/steven/tools/sidecar.launchd.err</string>
</dict>
</plist>
